# SecureScope — copy to `.env.local` for local development.
# Never commit real secrets. On Vercel: Project → Settings → Environment Variables.
#
# =============================================================================
# Supabase (authentication) — REQUIRED for login, signup, dashboard, admin APIs
# =============================================================================
# Get both values from Supabase Dashboard → Project Settings → API:
#   - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#   - anon public    → NEXT_PUBLIC_SUPABASE_ANON_KEY   (safe for browser; RLS applies)
# NEVER put the service role key in NEXT_PUBLIC_* or import it from client code.
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Optional: canonical origin for building absolute URLs (some hosts need this).
# NEXT_PUBLIC_SITE_URL=https://your-domain.example
#
# =============================================================================
# Cookiebot CMP (cookie consent) — public Domain Group ID only
# =============================================================================
# Cookiebot Dashboard → Domain groups → copy Domain Group ID:
# NEXT_PUBLIC_COOKIEBOT_DOMAIN_GROUP_ID=
#
# Optional: GA4 loads only after Cookiebot "statistics" consent (see ConsentAwareAnalytics.tsx)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
#
# === Client-visible (NEXT_PUBLIC_*) — URLs and flags only, never API secrets ===
# NEXT_PUBLIC_BASE_PATH=
# NEXT_PUBLIC_STRIPE_PRO_LINK=
#
# === AI (server routes only) ===
# GEMINI_API_KEY=
# OPENAI_API_KEY=
#
# === Threat intelligence & DNS (server) ===
# ABUSEIPDB_API_KEY=
# VIRUSTOTAL_API_KEY=
# SECURITYTRAILS_API_KEY=
# SHODAN_API_KEY=
# HETRIXTOOLS_API_KEY=
#
# === MXToolbox (server) ===
# Primary name used in blacklist / reputation routes:
# MX_TOOLBOX_API_KEY=
# Alias also read by lib/monitoring-hub/mxtoolbox-client.ts:
# MXTOOLBOX_API_KEY=
#
# === Twilio — /api/tools/phone-test (server) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
#
# === Monitoring hub / Playwright form tests (server) ===
# FORM_TEST_URL=
# MONITORING_ALLOW_PRIVATE_TARGETS=false   # never true in production
#
# === Cron & campaign blacklist route (server) ===
# See app/api/check-blacklist/route.ts for full semantics.
# CRON_SECRET=
# INSTANTLY_API_KEY=
# MONITORED_TARGETS=
# MONITORED_DOMAINS=
# MONITORED_DOMAIN=
# CAMPAIGN_ID=
# INSTANTLY_EMAIL_ACCOUNT_MAP=
# SLACK_WEBHOOK_URL=
# ALERT_EMAIL_WEBHOOK_URL=
# RESEND_API_KEY=
# ALERT_EMAIL_FROM=
# ALERT_EMAIL_TO=
#
# === Platform forms — POST /api/platform-forms ===
# Optional: forward sanitized submissions to Zapier, Slack, or your API (never expose secrets in client code).
# FORM_WEBHOOK_URL=
# FORM_WEBHOOK_SECRET=
# FORM_RATE_LIMIT_PER_IP_HOUR=40
#
# Future server integrations (do NOT put service keys in NEXT_PUBLIC_*):
# - Email: Resend, SendGrid, Microsoft Graph
# - Databases / CRM: Supabase (service role on server only), Notion, Airtable
# - Serverless: Vercel functions, Netlify functions
#
# === Payments (placeholders — wire only on server) ===
# STRIPE_SECRET_KEY=
# LEMONSQUEEZY_API_KEY=
# PADDLE_API_KEY=
#
# === Auth / SSO (placeholders) ===
# CLERK_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server only; never bundle into client
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_SECRET=
#
# === Vercel (auto-injected) ===
# VERCEL_URL=
