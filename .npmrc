# Treat this project as a standalone package, not as a member of a parent
# npm workspace. This prevents "workspace root confusion" that occurs when a
# package-lock.json (or package.json with workspaces) exists in a parent
# directory (e.g. /Users/<name>/ or C:\Users\<name>\) – a common accidental
# state on developer machines. Without this flag npm may resolve/install
# against the parent lockfile, which was generated on a different platform and
# therefore lacks platform-specific native binaries.
workspaces=false

# Explicitly include optional dependencies so that platform-specific native
# binaries are always installed. This overrides any global or per-user npm
# config that sets omit=optional. The following packages all ship optional
# platform binaries that MUST be present for the dev server and build to work:
#
#   macOS (Apple Silicon / arm64):
#     • lightningcss-darwin-arm64        – required by @tailwindcss/postcss
#     • @next/swc-darwin-arm64           – required by Next.js / Turbopack
#     • @tailwindcss/oxide-darwin-arm64  – required by tailwindcss v4
#     • @unrs/resolver-binding-darwin-arm64 – required by eslint-config-next
#
#   macOS (Intel / x64):
#     • lightningcss-darwin-x64          – required by @tailwindcss/postcss
#     • @next/swc-darwin-x64             – required by Next.js / Turbopack
#     • @tailwindcss/oxide-darwin-x64    – required by tailwindcss v4
#
#   Windows (x64):
#     • lightningcss-win32-x64-msvc      – required by @tailwindcss/postcss
#     • @next/swc-win32-x64-msvc         – required by Next.js / Turbopack
#     • @tailwindcss/oxide-win32-x64-msvc – required by tailwindcss v4
#     • @unrs/resolver-binding-win32-x64-msvc – required by eslint-config-next
#
#   Windows (ARM64):
#     • lightningcss-win32-arm64-msvc    – required by @tailwindcss/postcss
#     • @next/swc-win32-arm64-msvc       – required by Next.js / Turbopack
#     • @tailwindcss/oxide-win32-arm64-msvc – required by tailwindcss v4
#
#   Linux (x64):
#     • lightningcss-linux-x64-gnu       – required by @tailwindcss/postcss
#     • @next/swc-linux-x64-gnu          – required by Next.js / Turbopack
#     • @tailwindcss/oxide-linux-x64-gnu – required by tailwindcss v4
include=optional
