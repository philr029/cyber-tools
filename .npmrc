# Treat this project as a standalone package, not as a member of a parent
# npm workspace. This prevents "workspace root confusion" that occurs when a
# package-lock.json (or package.json with workspaces) exists in a parent
# directory (e.g. /Users/<name>/) – a common accidental state on developer
# machines. Without this flag npm may resolve/install against the parent
# lockfile, which was generated on a different platform and therefore lacks
# platform-specific native binaries such as lightningcss.darwin-arm64.node.
workspaces=false

# Explicitly include optional dependencies so that platform-specific native
# binaries are always installed. This overrides any global or per-user npm
# config that sets omit=optional. The following packages all ship optional
# platform binaries that MUST be present for the dev server and build to work:
#   • lightningcss-darwin-arm64  – required by @tailwindcss/postcss (Tailwind v4)
#   • @next/swc-darwin-arm64     – required by Next.js / Turbopack
#   • @tailwindcss/oxide-darwin-arm64 – required by tailwindcss v4
#   • @unrs/resolver-binding-darwin-arm64 – required by eslint-config-next
include=optional
